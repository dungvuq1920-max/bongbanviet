{
  "name": "bbv-n8n-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Workflow-as-code automation for BongBanViet social commerce channels.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx scripts/validate-workflows.ts",
    "build": "tsc -p tsconfig.json",
    "validate": "tsx scripts/validate-workflows.ts",
    "import:workflows": "tsx scripts/import-workflows.ts",
    "export:workflows": "tsx scripts/export-workflows.ts",
    "sync:from-n8n": "tsx scripts/sync-ui-changes.ts",
    "sync:watch": "tsx scripts/sync-ui-changes.ts --watch",
    "deploy:railway": "tsx scripts/deploy-after-build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
