# Local server
PORT=3000
FACEBOOK_AUTO_IMPORT=1
FACEBOOK_IMPORT_JSON_FILE=C:\Users\dungvuq1920\Desktop\facebook-posts.json

# Local -> public web sync
# Set these on your local machine when you want Desktop/facebook-posts.json
# to be pushed automatically to the public bongbanviet.com/facebook dashboard.
FACEBOOK_REMOTE_SYNC_URL=https://bongbanviet.com/api/fb-posts/import
FACEBOOK_REMOTE_SYNC_TOKEN=change-this-long-random-token

# Public web import protection
# Set this on Railway/public hosting. It must exactly match
# FACEBOOK_REMOTE_SYNC_TOKEN from the local machine.
FACEBOOK_IMPORT_TOKEN=change-this-long-random-token
# Only use this temporarily if you intentionally want an open public import endpoint.
FACEBOOK_ALLOW_PUBLIC_IMPORT=0

# Optional tuning
FACEBOOK_REMOTE_SYNC_TIMEOUT_MS=30000
FACEBOOK_IMPORT_POLL_MS=1200
JSON_BODY_LIMIT=5mb
