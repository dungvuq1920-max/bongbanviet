# n8n public API
N8N_BASE_URL=https://your-n8n-production.up.railway.app
N8N_API_KEY=replace_with_n8n_api_key
N8N_ACTIVATE_IMPORTED=false

# Optional validation control
SKIP_ENV_VALIDATION=false
REQUIRE_PLATFORM_ENVS=false

# Sync direct edits from n8n UI back to this repo
N8N_SYNC_INCLUDE_UNKNOWN=false
N8N_SYNC_PRESERVE_CREDENTIAL_REFERENCES=true
N8N_SYNC_CREDENTIAL_MANIFEST=true
N8N_SYNC_INTERVAL_SECONDS=60
N8N_SYNC_GIT_COMMIT=false
N8N_SYNC_GIT_PUSH=false

# Optional Telegram notification for UI sync
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI provider for content generation helpers
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Meta Graph API
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_GRAPH_VERSION=v19.0

# TikTok Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Shopee Open Platform
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=
SHOPEE_API_BASE_URL=https://partner.shopeemobile.com

# TikTok Shop official API
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_ACCESS_TOKEN=
TIKTOK_SHOP_ID=
TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com

# Source data endpoints
SOURCE_PRODUCT_API_URL=
SOURCE_VIDEO_API_URL=
SOURCE_RESULT_WEBHOOK_URL=
