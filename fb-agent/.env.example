# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model dùng để tạo content (mặc định: gpt-4o-mini — rẻ và nhanh)
OPENAI_MODEL=gpt-4o-mini

# ─── Facebook Graph API ────────────────────────────────────────────────────────
# Page ID của Facebook Page (không phải Profile ID)
FACEBOOK_PAGE_ID=123456789012345
# Page Access Token (xem hướng dẫn trong README để lấy)
FACEBOOK_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxx
# Phiên bản Graph API (khuyến nghị giữ nguyên hoặc dùng v19.0+)
FACEBOOK_GRAPH_VERSION=v19.0

# ─── Data Source ───────────────────────────────────────────────────────────────
# Đường dẫn đến file CSV (mặc định: ./posts.csv trong thư mục fb-agent)
CSV_PATH=./posts.csv

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression — mặc định chạy mỗi 2 phút
# Xem https://crontab.guru để tạo expression
SCHEDULER_CRON=*/2 * * * *

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARN | ERROR (mặc định: INFO)
LOG_LEVEL=INFO
