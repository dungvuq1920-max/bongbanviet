TELEGRAM_BOT_TOKEN=123456789:replace_with_botfather_token
TELEGRAM_ALLOWED_USER_IDS=123456789
# TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# Provider mac dinh: openai, gemini, claude, claude-code, auto
TELEGRAM_DEFAULT_PROVIDER=openai

OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Doi model neu tai khoan cua ban dung model khac.
OPENAI_MODEL=gpt-5.4-mini
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_CODE_MODEL=sonnet

# Claude Code mac dinh chi lap ke hoach. Doi thanh acceptEdits/auto/bypassPermissions neu that su muon cho bot sua code.
TELEGRAM_CLAUDE_CODE_PERMISSION_MODE=plan
TELEGRAM_WORKSPACE_DIR=.
